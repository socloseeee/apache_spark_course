# ═══════════════════════════════════════════════════════════════════
#  Шаблон переменных окружения.
#  Скопируйте в .env  (cp .env.example .env)  и при желании поменяйте значения.
#  Файл .env в git НЕ коммитится (см. .gitignore) — там «боевые» секреты.
# ═══════════════════════════════════════════════════════════════════

# --- Postgres ---
POSTGRES_USER=spark
POSTGRES_PASSWORD=spark
POSTGRES_DB=fintech

# --- MinIO (S3-совместимое хранилище) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Jupyter ---
# Токен для входа в JupyterLab: http://localhost:8888/lab?token=<этот токен>
JUPYTER_TOKEN=spark
